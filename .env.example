# .env.example - Example environment variables for QuillLeads
# 
# Rename this file to .env and fill in your actual credentials
# Never commit .env files to version control

# LinkedIn API
# Required for ContactHarvester LinkedIn integration
LINKEDIN_API_KEY=your_linkedin_api_key_here
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# Salesforce API
# Required for CRMDispatcher Salesforce integration
SALESFORCE_USERNAME=your_salesforce_username@example.com
SALESFORCE_PASSWORD=your_salesforce_password
SALESFORCE_SECURITY_TOKEN=your_salesforce_security_token
SALESFORCE_CLIENT_ID=your_consumer_key
SALESFORCE_CLIENT_SECRET=your_consumer_secret
SALESFORCE_DOMAIN=login  # or test for sandbox

# HubSpot API
# Required for CRMDispatcher HubSpot integration
HUBSPOT_API_KEY=your_hubspot_api_key_here

# Dodge Data & Analytics API
# Required for ProjectDiscoveryAgent construction project data
DODGE_API_KEY=your_dodge_api_key_here
DODGE_CLIENT_ID=your_dodge_client_id_here
DODGE_CLIENT_SECRET=your_dodge_client_secret_here

# ConstructConnect API
# Required for ProjectDiscoveryAgent construction project data
CONSTRUCTCONNECT_API_KEY=your_constructconnect_api_key_here
CONSTRUCTCONNECT_USERNAME=your_username_here
CONSTRUCTCONNECT_PASSWORD=your_password_here

# SAM.gov API
# Required for ProjectDiscoveryAgent government contract data
SAM_API_KEY=your_sam_api_key_here

# Pinecone
# Required for InventoryVectorDB migration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_environment  # e.g., us-west1-gcp
PINECONE_INDEX_NAME=quilleads-inventory

# Email Configuration
# Required for FinalPipeline email sending
EMAIL_SMTP_USER=noreply@quilleads.com
EMAIL_SMTP_PASSWORD=your_email_password_here
EMAIL_SMTP_HOST=smtp.quilleads.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_NAME="QuillLeads Team"
EMAIL_FROM_ADDRESS=noreply@quilleads.com

# Rate Limiting
# API rate limit configurations
LINKEDIN_RATE_LIMIT=50  # calls per minute
SALESFORCE_RATE_LIMIT=100  # calls per minute
HUBSPOT_RATE_LIMIT=200  # calls per minute

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=quilleads.log

# Application Configuration
DEBUG_MODE=False
MAX_WORKERS=10
CACHE_TTL=3600  # 1 hour in seconds